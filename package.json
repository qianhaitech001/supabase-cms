{
  "name": "supabase-cms-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable foreign-trade showcase site framework with Supabase, Vercel or Cloudflare Workers, and WordPress/WooCommerce migration tools.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "cf:build": "pnpm --filter @global-trade/site cf:build",
    "cf:deploy": "pnpm --filter @global-trade/site cf:deploy",
    "cf:preview": "pnpm --filter @global-trade/site cf:preview",
    "dev": "pnpm --filter @global-trade/site dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
