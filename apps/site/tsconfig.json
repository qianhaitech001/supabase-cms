{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@global-trade/core": ["../../packages/core/src/index.ts"],
      "@global-trade/migrator": ["../../packages/migrator/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
