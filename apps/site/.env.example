NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://example.com
# auto: use Supabase when configured, otherwise use local static data.
# static: force local typed static data.
# supabase: force Supabase data, falling back to local data only when credentials are missing or requests fail.
STOREFRONT_DATA_MODE=auto
# Visual tone preset for storefront pages: inshow, minimal, industrial, warm.
STOREFRONT_THEME=inshow
# Set to true only for multilingual storefronts. Single-language sites should keep it false.
NEXT_PUBLIC_STOREFRONT_I18N_ENABLED=false
# Default storefront locale used when i18n is disabled or no valid cookie is present: en, zh.
NEXT_PUBLIC_STOREFRONT_DEFAULT_LOCALE=en
# Comma-separated enabled storefront locales. Use one locale for single-language sites, e.g. en.
NEXT_PUBLIC_STOREFRONT_SUPPORTED_LOCALES=en
INQUIRY_TO_EMAIL=sales@example.com
MEDIA_UPLOAD_PROVIDER=supabase
SUPABASE_MEDIA_BUCKET=media
UPYUN_BUCKET=
UPYUN_OPERATOR=
UPYUN_PASSWORD=
UPYUN_API_ENDPOINT=https://v0.api.upyun.com
UPYUN_PUBLIC_BASE_URL=https://inshowhome.metainshow.com
UPYUN_PATH_PREFIX=uploads/admin
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_BUCKET=
ALI_OSS_REGION=
ALI_OSS_ENDPOINT=
ALI_OSS_PUBLIC_BASE_URL=
ALI_OSS_PATH_PREFIX=inshow-home
# Posts block editor rollout. Keep disabled until the staged editor is ready for a target environment.
NEXT_PUBLIC_POST_BLOCK_EDITOR_ENABLED=false
POST_EDITOR_ENGINE=lexical

# Comma-separated HTTPS iframe hosts allowed in article content previews and rendering.
TRUSTED_EMBED_HOSTS=www.youtube.com,player.vimeo.com,www.google.com
